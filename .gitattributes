# Force LF for all files
* text=auto eol=lf

# Explicitly enforce LF on these
secchk        text eol=lf
*.sh          text eol=lf
*.bash        text eol=lf
*.env         text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.json        text eol=lf

# Binaries — no conversion
*.png         binary
*.jpg         binary
*.mp4         binary
*.gz          binary
*.zip         binary
