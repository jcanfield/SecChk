    printf "  %sFile: %s%s\n\n" "$DIM" "$ENV_FILE" "$RST"
    printf "  %-30s %s\n" "KEY" "VALUE"
    sep
    printf "  %-30s %s\n" "DEFAULT_HOST"          "$DEFAULT_HOST"
    printf "  %-30s %s\n" "DEFAULT_WIN11_IP"       "$DEFAULT_WIN11_IP"
    printf "  %-30s %s\n" "DEFAULT_NETWORK_RANGE"  "$DEFAULT_NETWORK_RANGE"
    printf "  %-30s %s\n" "NUCLEI_OUTPUT_DIR"      "$NUCLEI_OUTPUT_DIR"
    printf "  %-30s %s\n" "NUCLEI_RATE_LIMIT"      "$NUCLEI_RATE_LIMIT"
    printf "  %-30s %s\n" "NUCLEI_CONCURRENCY"     "$NUCLEI_CONCURRENCY"
    local sk="${SHODAN_API_KEY:-}"
    [[ -n "$sk" ]] && sk="${sk:0:4}****" || sk="(not set)"
    printf "  %-30s %s\n" "SHODAN_API_KEY"         "$sk"
    printf "\n"
    teardown_scroll
}

