        printf "  %s 5%s  Windows 11 (SMB / RPC / web)\n"    "$C" "$RST"
        printf "  %s 6%s  Full audit to output file\n\n"     "$C" "$RST"
        printf "  %s-- PORT SCANNING (netcat) -------------------------------%s\n" "$W" "$RST"
        printf "  %s 7%s  Common ports\n"                    "$C" "$RST"
        printf "  %s 8%s  Custom port range\n"               "$C" "$RST"
        printf "  %s 9%s  Banner grab\n\n"                   "$C" "$RST"
        printf "  %s-- ADDITIONAL TOOLS -------------------------------------%s\n" "$W" "$RST"
        printf "  %s10%s  WHOIS lookup\n"                    "$C" "$RST"
        printf "  %s11%s  DNS enumeration\n"                 "$C" "$RST"
        printf "  %s12%s  SSL/TLS certificate check\n"       "$C" "$RST"
        printf "  %s13%s  HTTP security headers\n"           "$C" "$RST"
        printf "  %s14%s  Shodan host lookup\n\n"            "$C" "$RST"
        printf "  %s-- UTILITY ----------------------------------------------%s\n" "$W" "$RST"
        printf "  %s15%s  Configuration\n"                   "$C" "$RST"
        printf "  %s16%s  System information\n" "$C" "$RST" 
        printf "  %s h%s  Help\n"                            "$C" "$RST"
        printf "  %s q%s  Quit\n\n"                          "$C" "$RST"
        printf "  Select: "
        read -r choice
        case "$choice" in
            1)  do_scan1 ;;     2)  do_scan2 ;;     3)  do_scan3 ;;
            4)  do_scan4 ;;     5)  do_scan5 ;;     6)  do_scan6 ;;
            7)  do_nc_common ;; 8)  do_nc_range ;;  9)  do_nc_banner ;;
            10) do_whois ;;     11) do_dns ;;        12) do_ssl ;;
            13) do_headers ;;   14) do_shodan ;;     15) do_config ;;
            h|H|help) do_help; pause ;;
            q|Q|quit|exit) printf "\n  %sGoodbye.%s\n\n" "$C" "$RST"; exit 0 ;;
            *) warn "Unknown option: $choice"; sleep 1 ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Entry point — flag or interactive
# ---------------------------------------------------------------------------
case "${1:-}" in
    --scan-cve)   print_banner; do_scan1 ;;
    --scan-crit)  print_banner; do_scan2 ;;
    --scan-range) print_banner; do_scan3 ;;
    --scan-infra) print_banner; do_scan4 ;;
    --scan-win11) print_banner; do_scan5 ;;
    --scan-audit) print_banner; do_scan6 ;;
    --nc-common)  print_banner; do_nc_common ;;
    --nc-range)   print_banner; do_nc_range ;;
    --nc-banner)  print_banner; do_nc_banner ;;
    --whois)      print_banner; do_whois ;;
    --dns)        print_banner; do_dns ;;
    --ssl)        print_banner; do_ssl ;;
    --headers)    print_banner; do_headers ;;
    --shodan)     print_banner; do_shodan ;;
    --config)     print_banner; do_config ;;
    --sysinfo) print_banner; do_sysinfo ;;
    -h|--help)    do_help ;;
    "")           main_menu ;;
    *) printf "  Unknown option: %s\n  Run: ./secchk --help\n" "$1"; exit 1 ;;
esac