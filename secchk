#!/usr/bin/env bash
# secchk - Security Check Tool v0.2
# ---------------------------------------------------------------------------
# Load .env
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.env"
if [[ -f "$ENV_FILE" ]]; then set -a; source "$ENV_FILE"; set +a; fi

DEFAULT_HOST="${DEFAULT_HOST:-http://localhost}"
DEFAULT_WIN11_IP="${DEFAULT_WIN11_IP:-192.168.1.100}"
DEFAULT_NETWORK_RANGE="${DEFAULT_NETWORK_RANGE:-192.168.1.0/24}"
NUCLEI_OUTPUT_DIR="${NUCLEI_OUTPUT_DIR:-./results}"
NUCLEI_RATE_LIMIT="${NUCLEI_RATE_LIMIT:-150}"
NUCLEI_CONCURRENCY="${NUCLEI_CONCURRENCY:-25}"

# ---------------------------------------------------------------------------
# Colors  (change the trailing number to swap accent:
#   31=red  32=green  33=yellow  34=blue  35=magenta  36=teal)
# ---------------------------------------------------------------------------
R="$(printf '\033[1;31m')"
G="$(printf '\033[1;32m')"
Y="$(printf '\033[1;33m')"
B="$(printf '\033[1;34m')"
C="$(printf '\033[1;34m')"   # accent — currently bright blue
W="$(printf '\033[1;37m')"
DIM="$(printf '\033[2m')"
RST="$(printf '\033[0m')"

# Dark Blue
C="$(printf '\033[0;34m')"   # dark blue
C="$(printf '\033[1;34m')"   # bright blue (bolder)

# Dark Red
C="$(printf '\033[0;31m')"   # dark red
C="$(printf '\033[1;31m')"   # bright red (bolder)

# ---------------------------------------------------------------------------
# Utility functions  — all defined at GLOBAL scope
# ---------------------------------------------------------------------------
info()    { printf "  %s[INFO]%s  %s\n" "$C" "$RST" "$*"; }
ok()      { printf "  %s[ OK ]%s  %s\n" "$G" "$RST" "$*"; }
warn()    { printf "  %s[WARN]%s  %s\n" "$Y" "$RST" "$*"; }
sep()     { printf "  %s────────────────────────────────────────────────%s\n" "$DIM" "$RST"; }
heading() { printf "\n  %s%s%s\n" "$W" "$*" "$RST"; sep; }
pause() {
    printf "\n  %sPress Enter to return to menu...%s" "$DIM" "$RST" >/dev/tty
    read -r </dev/tty
}

setup_scroll() {
    clear
    _draw_banner
}

teardown_scroll() {
    pause
    clear
    main_menu  # force return to menu if loop doesn't catch it
    exit 0
}
ask() {
    local label="$1" default="$2"
    # Print prompt below the heading, inside the scroll region
    printf "  %s%s%s [%s%s%s]: " "$C" "$label" "$RST" "$DIM" "$default" "$RST" >/dev/tty
    read -r _ans </dev/tty
    printf "%s" "${_ans:-$default}"
}

confirm() {
    printf "  %s%s [y/N]%s " "$Y" "$1" "$RST" >/dev/tty
    read -r _c </dev/tty
    [[ "$_c" =~ ^[Yy]$ ]]
}

need() {
    if ! command -v "$1" >/dev/null 2>&1; then
        warn "'$1' not found in PATH."
        confirm "Continue anyway?" || return 1
    fi
    return 0
}

mk_outdir() { mkdir -p "$NUCLEI_OUTPUT_DIR"; }

