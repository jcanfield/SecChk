        print_banner
        printf "  %s-- NUCLEI SCANS ----------------------------------------%s\n" "$W" "$RST"
        printf "  %s 1%s  Basic CVE scan\n"                  "$C" "$RST"
        printf "  %s 2%s  Critical / high severity only\n"   "$C" "$RST"
        printf "  %s 3%s  Network range scan (targets.txt)\n" "$C" "$RST"
