# ---------------------------------------------------------------------------
# Nuclei wrapper
# ---------------------------------------------------------------------------
run_nuclei() {
    need nuclei || return 1
    mk_outdir
    local ts outfile
    ts="$(date +%Y%m%d-%H%M%S)"
    outfile="${NUCLEI_OUTPUT_DIR}/${ts}-nuclei.txt"
    printf "  %s» nuclei %s -rate-limit %s -c %s%s\n\n" \
        "$DIM" "$*" "$NUCLEI_RATE_LIMIT" "$NUCLEI_CONCURRENCY" "$RST"

    # -v = verbose, -stats = live stats bar, tee writes to screen AND file
    nuclei "$@" \
        -rate-limit "$NUCLEI_RATE_LIMIT" \
        -c          "$NUCLEI_CONCURRENCY" \
        -v \
        -stats \
        2>&1 | tee "$outfile" | while IFS= read -r line; do
        case "${line,,}" in
            *"[critical]"*) printf "  %s%s%s\n" "$R"   "$line" "$RST" ;;
            *"[high]"*)     printf "  %s%s%s\n" "$Y"   "$line" "$RST" ;;
            *"[medium]"*)   printf "  %s%s%s\n" "$C"   "$line" "$RST" ;;
            *"[low]"*)      printf "  %s%s%s\n" "$DIM" "$line" "$RST" ;;
            *"[inf]"*)      printf "  %s%s%s\n" "$DIM" "$line" "$RST" ;;
            *"[err]"*)      printf "  %s%s%s\n" "$Y"   "$line" "$RST" ;;
            *"[ftl]"*)      printf "  %s%s%s\n" "$R"   "$line" "$RST" ;;
            *)              printf "  %s\n"             "$line"        ;;
        esac
    done

    printf "\n"
    ok "Log saved to $outfile"
}

# ---------------------------------------------------------------------------
# Nuclei scan functions
# ---------------------------------------------------------------------------
do_scan1() {
    setup_scroll
    heading "Scan 1 — Basic CVE Scan"
    local h; h="$(ask "Target host" "$DEFAULT_HOST")"
    info "Running CVE templates against $h"
    run_nuclei -u "$h" -t cves/
    teardown_scroll
}

do_scan2() {
    setup_scroll
    heading "Scan 2 — Critical / High Severity"
    local h; h="$(ask "Target host" "$DEFAULT_HOST")"
    info "Scanning $h — severity: critical, high"
    run_nuclei -u "$h" -severity critical,high
    teardown_scroll
}

do_scan3() {
    setup_scroll
    heading "Scan 3 — Network Range (targets.txt)"
    local f; f="$(ask "Targets file" "./targets.txt")"
    if [[ ! -f "$f" ]]; then
        warn "File not found: $f"
        if need nmap; then
            info "Discovering hosts on $DEFAULT_NETWORK_RANGE ..."
            nmap -sn "$DEFAULT_NETWORK_RANGE" -oG - 2>/dev/null \
                | awk '/Up$/{print $2}' > "$f"
            ok "Wrote $(wc -l < "$f") hosts to $f"
        fi
    fi
    run_nuclei -l "$f" -t cves/ -severity critical,high,medium
    teardown_scroll
}

do_scan4() {
    setup_scroll
    heading "Scan 4 — Linux / Infrastructure Full Scan"
    local h; h="$(ask "Target host" "$DEFAULT_HOST")"
    info "Templates: network/ exposures/ misconfiguration/ cves/"
    run_nuclei -u "$h" -t network/ -t exposures/ -t misconfiguration/ -t cves/
    teardown_scroll
}

do_scan5() {
    setup_scroll
    heading "Scan 5 — Windows 11 (SMB / RPC / Web)"
    local h; h="$(ask "Win11 IP" "$DEFAULT_WIN11_IP")"
    info "Templates: network/smb/ cves/ misconfiguration/"
    run_nuclei -u "$h" -t network/smb/ -t cves/ -t misconfiguration/
    teardown_scroll
}

do_scan6() {
    setup_scroll
    heading "Scan 6 — Full Audit to File"
    local f; f="$(ask "Targets file" "./targets.txt")"
    if [[ ! -f "$f" ]]; then
        warn "File not found: $f"
        confirm "Create with one host?" || { teardown_scroll; return 1; }
        local h; h="$(ask "Host" "$DEFAULT_HOST")"
        printf "%s\n" "$h" > "$f"
        ok "Created $f"
    fi
    local out="${NUCLEI_OUTPUT_DIR}/audit-$(date +%Y%m%d-%H%M%S).txt"
    mk_outdir
    info "Output: $out"
    run_nuclei -l "$f" -t cves/ -t misconfiguration/ -t default-logins/ \
        -severity critical,high -o "$out"
    teardown_scroll
}

# ---------------------------------------------------------------------------
# Netcat port scanning
# ---------------------------------------------------------------------------
do_nc_common() {
    setup_scroll
    heading "Port Scan — Common Ports"
    need nc || { teardown_scroll; return 1; }
    local h; h="$(ask "Target host" "$DEFAULT_HOST")"
    h="${h#http://}"; h="${h#https://}"
    local -a PORTS=(21 22 23 25 53 80 110 111 143 443 445
                    3306 3389 5432 5900 6379 8080 8443 27017)
    printf "\n  %-8s %-18s %s\n" "PORT" "SERVICE" "STATUS"
    sep
    for p in "${PORTS[@]}"; do
        local svc
        svc="$(getent services "${p}/tcp" 2>/dev/null | awk '{print $1}')"
        svc="${svc:-?}"
        if nc -z -w 1 "$h" "$p" 2>/dev/null; then
            printf "  %s%-8s %-18s OPEN%s\n"   "$G"   "$p" "$svc" "$RST"
        else
            printf "  %s%-8s %-18s closed%s\n" "$DIM" "$p" "$svc" "$RST"
        fi
    done
    printf "\n"
    ok "Scan complete — $h"
    teardown_scroll
}

do_nc_range() {
    setup_scroll
    heading "Port Scan — Custom Range"
    need nc || { teardown_scroll; return 1; }
    local h; h="$(ask "Target host" "$DEFAULT_HOST")"
    h="${h#http://}"; h="${h#https://}"
    local s; s="$(ask "Start port" "1")"
    local e; e="$(ask "End port" "1024")"
    info "Scanning $h ports $s to $e ..."
    local found=0
    for (( p=s; p<=e; p++ )); do
        if nc -z -w 1 "$h" "$p" 2>/dev/null; then
            local svc
            svc="$(getent services "${p}/tcp" 2>/dev/null | awk '{print $1}')"
            svc="${svc:-?}"
            printf "  %s%-8s %-18s OPEN%s\n" "$G" "$p" "$svc" "$RST"
            found=$(( found + 1 ))
        fi
    done
    printf "\n"
    ok "Found $found open port(s) on $h"
    teardown_scroll
}

do_nc_banner() {
    setup_scroll
    heading "Banner Grab"
    need nc || { teardown_scroll; return 1; }
    local h; h="$(ask "Target host" "$DEFAULT_HOST")"
    h="${h#http://}"; h="${h#https://}"
    local p; p="$(ask "Port" "80")"
    info "Grabbing banner from $h:$p ..."
    printf "\n"
    printf "HEAD / HTTP/1.0\r\n\r\n" \
        | nc -w 3 "$h" "$p" 2>/dev/null \
        | head -20 \
        | while IFS= read -r line; do
            printf "  %s%s%s\n" "$C" "$line" "$RST"
        done
    printf "\n"
    ok "Done"
    teardown_scroll
}

# ---------------------------------------------------------------------------
# Additional tools
# ---------------------------------------------------------------------------
do_whois() {
    setup_scroll
    heading "WHOIS Lookup"
    need whois || { teardown_scroll; return 1; }
    local t; t="$(ask "Domain / IP" "$DEFAULT_HOST")"
    t="${t#http://}"; t="${t#https://}"
    printf "\n"
    whois "$t" 2>/dev/null | head -50 \
        | while IFS= read -r line; do
            printf "  %s%s%s\n" "$DIM" "$line" "$RST"
        done
    teardown_scroll
}

do_dns() {
    setup_scroll
    heading "DNS Enumeration"
    local t; t="$(ask "Domain" "$DEFAULT_HOST")"
    t="${t#http://}"; t="${t#https://}"
    printf "\n"
    for rtype in A AAAA MX NS TXT SOA CNAME; do
        local r; r="$(dig +short "$t" "$rtype" 2>/dev/null)"
        [[ -n "$r" ]] && printf "  %s%-8s%s  %s\n" "$B" "$rtype" "$RST" "$r"
    done
    printf "\n"
    ok "DNS enumeration complete"
    teardown_scroll
}

do_ssl() {
    setup_scroll
    heading "SSL/TLS Certificate Check"
    need openssl || { teardown_scroll; return 1; }
    local h; h="$(ask "Hostname (no https://)" "$DEFAULT_HOST")"
    h="${h#http://}"; h="${h#https://}"
    local p; p="$(ask "Port" "443")"
    printf "\n"
    echo "" \
        | openssl s_client -connect "${h}:${p}" -servername "$h" 2>/dev/null \
        | openssl x509 -noout -text 2>/dev/null \
        | grep -E "(Subject:|Issuer:|Not Before|Not After|DNS:)" \
        | while IFS= read -r line; do
            printf "  %s%s%s\n" "$C" "$line" "$RST"
        done
    printf "\n"
    ok "TLS check complete"
    teardown_scroll
}

do_sysinfo() {
    setup_scroll
    heading "System Information"

    # Linux logo (optional — skip gracefully if not installed)
    if command -v linuxlogo >/dev/null 2>&1; then
        linuxlogo
        printf "\n"
    fi

    # Kernel + distro
    printf "  %s%s%s\n\n" "$DIM" "$(uname -a)" "$RST"

    if command -v lsb_release >/dev/null 2>&1; then
        lsb_release -a 2>/dev/null | while IFS= read -r line; do
            printf "  %s%s%s\n" "$DIM" "$line" "$RST"
        done
        printf "\n"
    fi

    # Language / tool versions
    for cmd in "python3 --version" "pip --version" "docker --version" "node --version" "npm --version"; do
        local bin="${cmd%% *}"
        if command -v "$bin" >/dev/null 2>&1; then
            local ver; ver="$(eval "$cmd" 2>/dev/null)"
            printf "  %s%-10s%s %s\n" "$C" "$bin" "$RST" "$ver"
        fi
    done
    printf "\n"

    # Memory
    printf "  %sMemory Usage%s\n" "$W" "$RST"; sep
    free -h | while IFS= read -r line; do
        printf "  %s%s%s\n" "$DIM" "$line" "$RST"
    done
    printf "\n"

    # Uptime
    printf "  %sSystem Uptime%s\n" "$W" "$RST"; sep
    local now up users load1 load5
    now="$(date '+%H:%M:%S')"
    up="$(uptime -p 2>/dev/null || uptime)"
    users="$(who | wc -l)"
    load1="$(awk '{print $1}' /proc/loadavg)"
    load5="$(awk '{print $2}' /proc/loadavg)"
    printf "  %sCurrent-time%s    :  %s%s%s\n"   "$DIM" "$RST" "$C" "$now"   "$RST"
    printf "  %sSystem-uptime%s   :  %s%s%s\n"   "$DIM" "$RST" "$C" "$up"    "$RST"
    printf "  %sNumber-of-users%s :  %s%s%s\n"   "$DIM" "$RST" "$C" "$users" "$RST"
    printf "  %sLoad-average%s\n"                "$DIM" "$RST"
    printf "    %s1-min%s          :  %s%s%s\n"  "$DIM" "$RST" "$C" "$load1" "$RST"
    printf "    %s5-min%s          :  %s%s%s\n"  "$DIM" "$RST" "$C" "$load5" "$RST"
    printf "\n"

    teardown_scroll
}

do_headers() {
    setup_scroll
    heading "HTTP Security Headers"
    need curl || { teardown_scroll; return 1; }
    local u; u="$(ask "URL" "$DEFAULT_HOST")"
    printf "\n"
    local hdrs; hdrs="$(curl -sI --max-time 10 "$u" 2>/dev/null)"
    printf "%s\n" "$hdrs" | while IFS= read -r line; do
        local ll="${line,,}"
        case "$ll" in
            *strict-transport*)   printf "  %s%s%s\n" "$G"   "$line" "$RST" ;;
            *content-security-p*) printf "  %s%s%s\n" "$G"   "$line" "$RST" ;;
            *x-frame-options*)    printf "  %s%s%s\n" "$G"   "$line" "$RST" ;;
            *x-content-type*)     printf "  %s%s%s\n" "$G"   "$line" "$RST" ;;
            *permissions-policy*) printf "  %s%s%s\n" "$G"   "$line" "$RST" ;;
            *server:*)            printf "  %s%s%s\n" "$Y"   "$line" "$RST" ;;
            *)                    printf "  %s%s%s\n" "$DIM" "$line" "$RST" ;;
        esac
    done
    printf "\n"
    local missing=()
    printf "%s\n" "$hdrs" | grep -qi "Strict-Transport-Security" || missing+=("HSTS")
    printf "%s\n" "$hdrs" | grep -qi "Content-Security-Policy"   || missing+=("CSP")
    printf "%s\n" "$hdrs" | grep -qi "X-Frame-Options"           || missing+=("X-Frame-Options")
    printf "%s\n" "$hdrs" | grep -qi "X-Content-Type-Options"    || missing+=("X-Content-Type-Options")
    printf "%s\n" "$hdrs" | grep -qi "Permissions-Policy"        || missing+=("Permissions-Policy")
    if [[ ${#missing[@]} -gt 0 ]]; then
        warn "Missing headers:"
        for hh in "${missing[@]}"; do
            printf "  %s  x  %s%s\n" "$R" "$hh" "$RST"
        done
    else
        ok "All key security headers present"
    fi
    teardown_scroll
}

do_shodan() {
    setup_scroll
    heading "Shodan Host Lookup"
    if [[ -z "${SHODAN_API_KEY:-}" ]]; then
        warn "SHODAN_API_KEY not set in .env"
        teardown_scroll; return 1
    fi
    need curl || { teardown_scroll; return 1; }
    local h; h="$(ask "IP address" "")"
    printf "\n"
    curl -s "https://api.shodan.io/shodan/host/${h}?key=${SHODAN_API_KEY}" \
        | python3 -m json.tool 2>/dev/null \
        | head -60 \
        | while IFS= read -r line; do
            printf "  %s%s%s\n" "$C" "$line" "$RST"
        done
    teardown_scroll
}

